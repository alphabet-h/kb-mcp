/target/

# fastembed-rs が cache_dir 未解決時に使うローカルフォールバック
.fastembed_cache/

# Claude Code (local settings, reproducible skills)
CLAUDE.local.md
*.local.md
.claude/settings.local.json
.claude/scheduled_tasks.lock
.agents/
.remember/
.mcp.json

# Runtime config placed next to the binary (user-local). Template is kb-mcp.toml.example.
kb-mcp.toml

# Deployment recipe templates under examples/deployments/ are meant to be
# committed (they are example artifacts, not user-local runtime files).
!examples/deployments/**/.mcp.json
!examples/deployments/**/kb-mcp.toml
