# kb-mcp 設定ファイルのサンプル。
#
# このファイルをバイナリ (kb-mcp / kb-mcp.exe) と**同じディレクトリ**に
# `kb-mcp.toml` という名前でコピーして使う。
# CLI 引数で明示指定した項目が常に優先されるため、ここでは運用時の既定値を
# 書いておく想定。すべてのキーは optional (省略すればビルトイン既定値)。

# 対象 knowledge-base ディレクトリの絶対パス。
# 指定すると `--kb-path` を省略できる。
#kb_path = "/path/to/knowledge-base"

# 既定の埋め込みモデル。
#   bge-small-en-v1.5 … 英語特化、384 次元、~130 MB (既定)
#   bge-m3            … 多言語 (日本語 OK)、1024 次元、~2.3 GB
#model = "bge-m3"

# 既定の cross-encoder reranker。
#   none       … 無効 (既定)
#   bge-v2-m3  … BAAI/bge-reranker-v2-m3 (多言語、~2.3 GB、日本語推奨)
#   jina-v2-ml … jinaai/jina-reranker-v2-base-multilingual (~1.2 GB、軽量多言語)
#   bge-base   … BAAI/bge-reranker-base (英/中、~280 MB)
#reranker = "bge-v2-m3"

# reranker が有効なとき、各 `search` 呼び出しで自動的に rerank を適用するか。
# MCP ツール `search` の `rerank` パラメータで個別上書き可能。
#rerank_by_default = true

# fastembed のモデルキャッシュディレクトリ。
# 既に環境変数 `FASTEMBED_CACHE_DIR` が設定されていれば env が優先される。
# `hf download` で事前 DL した HF Hub キャッシュ (~/.cache/huggingface/hub)
# を指しておくと、fastembed の TLS で DL 失敗する環境でも流用できる。
#fastembed_cache_dir = "/home/yabushita/.cache/huggingface/hub"

# Markdown チャンク化時に除外する見出しの substring リスト。
# 3 状態セマンティクス:
#   - 省略 (キー自体を書かない)     … 既定 ["次の深堀り候補"] で除外
#   - 明示的な空配列 `[]`           … 除外なし (全見出しをチャンク化)
#   - 独自リスト                     … 既定を完全に上書き (merge ではない)
# マッチは substring (見出しテキストに含まれていれば除外)。
# 例: 「参考リンク」セクションと、深堀り候補の 2 つを落としたい場合:
#exclude_headings = ["次の深堀り候補", "参考リンク"]
# 例: 既定の「次の深堀り候補」除外も外して何も除外しない場合:
#exclude_headings = []

# 検索時のチャンク品質フィルタ (feature 13)。
# enabled を false にすると MCP search / CLI search / get_connection_graph
# すべてでフィルタが無効になり、従来の全件返却動作に戻る。
# threshold は 0.0 から 1.0 の範囲で、未満のスコアのチャンクを除外する。
# 既定はフィルタ有効 + threshold 0.3。
[quality_filter]
enabled = true
threshold = 0.3

# `get_best_practice` MCP ツールのファイル解決テンプレート (feature 16)。
# 先頭から順に `{target}` を置換して kb_path 相対で探し、最初に見つかった
# ファイルを返す。`target` 引数は安全のため canonicalize + kb_path 配下の
# チェックが入る。省略時は ["best-practices/{target}/PERFECT.md"] (legacy)。
[best_practice]
path_templates = [
  "best-practices/{target}/PERFECT.md",  # ai_organization 既定構造
  "docs/{target}.md",                    # docs/ 配置
  "guides/{target}/README.md",           # guide 風
]
